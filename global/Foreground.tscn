[gd_scene load_steps=2 format=3 uid="uid://dio40kx3rpgou"]

[sub_resource type="GDScript" id="GDScript_7y6t4"]
resource_name = "foreground"
script/source = "extends CanvasLayer

func _ready(): 
	$ColorRect.color = PALETTE.fg
	$ColorRect.modulate = Color(\"FFF\")
	visible = true

func _fade_in(speed = 2.0):
	var fade_in = get_tree().create_tween().set_ease(Tween.EASE_IN_OUT).set_trans(Tween.TRANS_QUAD)
	fade_in.tween_property($ColorRect, \"modulate\", Color(\"FFF0\"), speed)
	await get_tree().create_timer(speed).timeout
	$ColorRect.visible = false

func _fade_out(speed = 2.0):
	$ColorRect.visible = true
	var fade_in = get_tree().create_tween().set_ease(Tween.EASE_IN_OUT).set_trans(Tween.TRANS_QUAD)
	fade_in.tween_property($ColorRect, \"modulate\", Color(\"FFF\"), speed)
	await get_tree().create_timer(speed).timeout
"

