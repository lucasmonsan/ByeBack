resource_name = "background"
script/source = "extends CanvasLayer

func _interpolate(new_color, speed = 1.0):
	var interpolate = get_tree().create_tween().set_ease(Tween.EASE_IN_OUT).set_trans(Tween.TRANS_QUAD)
	interpolate.tween_property($ColorRect, \"color\", new_color, speed)

func _change(new_color): $ColorRect.color = new_color"

