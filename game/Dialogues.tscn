[sub_resource type="GDScript" id="GDScript_03fvf"]
resource_name = "speech"
script/source = "extends PanelContainer

func _start(text, time = 0.05):
	SAVE._step_once()
	var text_array = text.split(\". \")
	var array_count = 0
	$RichText.text = \"[center]\" + text_array[array_count]
	$RichText.visible_characters = 0
	$RichText.visible_ratio = 0
	$RichText.visible = true
	
	while (array_count < text_array.size()):
		while $RichText.visible_characters < ($RichText.text.length() - extract_bbcode_tags($RichText.text)):
			$RichText.visible_characters += 1
			await (get_tree().create_timer(time).timeout)
		
		if (array_count < text_array.size() -1):
			await (get_tree().create_timer(time * 5).timeout)
			array_count += 1
			$RichText.text += \" \" + text_array[array_count]
		else: break
	
	SAVE._next_step()

func extract_bbcode_tags(string):
	var tags = \"\"
	var inside = false
	
	for character in string:
		if (character == \"[\"): inside = true
		if (inside): tags += character
		if (character == \"]\"): inside = false
	return tags.length()
"

