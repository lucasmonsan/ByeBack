[sub_resource type="GDScript" id="GDScript_jrkly"]
resource_name = "answers"
script/source = "extends PanelContainer

@export var choice1: Button = null
@export var choice2: Button = null
@export var choice3: Button = null
@export var choice4: Button = null

#------------------------------------------------------------------------------#

func _normal(p_choice1 = \"\", p_choice2 = \"\", p_choice3 = \"\", p_choice4 = \"\"):
	SAVE._step_once()
	SAVE.touch = false
	SAVE.choice = \"\"
	
	choice1.text = p_choice1
	choice2.text = p_choice2
	choice3.text = p_choice3
	choice4.text = p_choice4
	
	choice1.visible = (p_choice1 != \"\")
	choice2.visible = (p_choice2 != \"\")
	choice3.visible = (p_choice3 != \"\")
	choice4.visible = (p_choice4 != \"\")
	
	visible = true
	get_tree().create_tween().tween_property(self, \"modulate\", Color(\"FFF\"), 0.5).set_ease(Tween.EASE_IN_OUT)
	await get_tree().create_timer(0.5).timeout
	SAVE.touch = true

#------------------------------------------------------------------------------#

func _handle_click(choice):
	SAVE.touch = false
	SAVE.choice = choice.text
	get_tree().create_tween().tween_property(self, \"modulate\", Color(\"FFF0\"), 0.5).set_ease(Tween.EASE_IN_OUT)
	await get_tree().create_timer(0.5).timeout
	visible = false
	SAVE._next_step()
	#$Click.play()

#------------------------------------------------------------------------------#

func _on_button_1_pressed(): if SAVE.touch: _handle_click(choice1)
func _on_button_2_pressed(): if SAVE.touch: _handle_click(choice2)
func _on_button_3_pressed(): if SAVE.touch: _handle_click(choice3)
func _on_button_4_pressed(): if SAVE.touch: _handle_click(choice4)
"

