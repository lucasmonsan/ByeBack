[sub_resource type="GDScript" id="GDScript_dxpal"]
resource_name = "dialogues"
script/source = "extends CanvasLayer

func _ready(): SAVE.step = 1

func _start(npc, speed = 0.5):
	SAVE._step_once()
	npc.visible = true
	get_tree().create_tween().tween_property(npc, \"modulate\", Color(\"FFF\"), 0.5).set_ease(Tween.EASE_IN_OUT)
	await get_tree().create_timer(speed).timeout
	get_tree().create_tween().tween_property($speech_panel, \"modulate\", Color(\"FFF\"), 0.5).set_ease(Tween.EASE_IN_OUT)
	await get_tree().create_timer(speed/2).timeout
	SAVE._next_step()

func _process(_delta):
	if (SAVE.day == 1):
		if (SAVE.step == 1): _start($grandpa)
		elif (SAVE.step == 2): 
			$speech_panel._start(\"[b]Welcome[/b] to the online bb code generator Like link code, html [url=https://www.yttags.com]bbcode[/url]! Edit your text and click the button to get your bb code.\")
			$grandpa.play(\"talk\")
		elif (SAVE.step == 3):
			$grandpa.play(\"idle\")
			$answear_panel._normal(\"Acordar\", \"Soneca\", \"Dar o cú\")
		elif (SAVE.step == 4): 
			$speech_panel._start(\"[wave]Welcome[/wave] to the online bb code generator Like link code, html [url=https://www.yttags.com]bbcode[/url]! Edit your text and click the button to get your bb code.\")
			$grandpa.play(\"talk\")
"

