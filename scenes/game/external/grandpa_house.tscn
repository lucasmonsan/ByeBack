[sub_resource type="GDScript" id="GDScript_aebht"]
resource_name = "grandpa_house"
script/source = "extends CanvasLayer

func _ready():
	var grandpa = get_tree().create_tween().set_ease(Tween.EASE_IN_OUT).set_trans(Tween.TRANS_QUAD)
	grandpa.tween_property($Control_house_bg, \"position\", Vector2($Control_house_bg.position.x,0),2.0)
	grandpa.parallel().tween_property($Control_house_bg/sky, \"modulate\", Color(\"FFF0\"), 1.0).set_delay(1.5)
	grandpa.parallel().tween_property(BgSfx.strong_wind, \"volume_db\", -80, 2.0)
	grandpa.parallel().tween_property(BgMusic.title, \"volume_db\", -80, 3.0)
	BgSfx.forest.play()
"

